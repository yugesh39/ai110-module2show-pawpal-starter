classDiagram
    class Owner {
        -string name
        -string available_start
        -string available_end
        -List~Pet~ pets
        +add_pet(pet: Pet) void
        +available_minutes() int
    }

    class Pet {
        -string name
        -string species
        -string breed
        -List~Task~ tasks
        +add_task(task: Task) void
        +edit_task(task_id: string, updates: dict) bool
        +remove_task(task_id: string) void
        +mark_task_complete(task_id: string) bool
    }

    class Task {
        -string id
        -string name
        -int duration_minutes
        -string priority
        -string category
        -string preferred_time
        -bool completed
        -string frequency
        +priority_value() int
        +mark_complete() void
        +mark_incomplete() void
        +next_occurrence() Task
        +edit(kwargs: dict) void
    }

    class Scheduler {
        -Owner owner
        -Pet pet
        +generate_plan() dict
        +detect_conflicts() List~string~
        +sort_by_time(tasks: List~Task~) List~Task~
        +filter_tasks(completed: bool, pet_name: string) List~Task~
        +mark_task_complete(task_id: string) bool
        -_sort_tasks(tasks: List~Task~) List~Task~
        -_allocate_time(current_time: string, duration: int) tuple
    }

    Owner "1" o-- "many" Pet : owns
    Pet "1" *-- "many" Task : has
    Scheduler "1" --> "1" Owner : uses
    Scheduler "1" --> "1" Pet : uses

    note for Task "frequency: \"once\" | \"daily\" | \"weekly\".\nnext_occurrence() returns a fresh, incomplete\ncopy for recurring tasks; called by\nPet.mark_task_complete(), not by most callers directly."
    note for Pet "mark_task_complete() marks the task done\nand, if frequency is daily/weekly, appends the\nresult of task.next_occurrence() back onto\nthis pet's own task list."
    note for Scheduler "Constructed with ONE owner + ONE pet, but\ndetect_conflicts(), sort_by_time(), filter_tasks(),\nand mark_task_complete() all operate across\nEVERY pet in owner.pets -- only generate_plan()\nand _sort_tasks()/_allocate_time() are scoped to self.pet."